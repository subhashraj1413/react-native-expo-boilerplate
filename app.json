{
  "expo": {
    "name": "React Native Expo Boilerplate",
    "slug": "react-native-expo-boilerplate",
    "scheme": "reactnativeexpoboilerplate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID for secure sign in."
        }
      ],
      "expo-secure-store"
    ],
    "ios": {
      "bundleIdentifier": "com.reactnativeexpoboilerplate",
      "supportsTablet": true
    },
    "android": {
      "package": "com.reactnativeexpoboilerplate"
    }
  }
}
